# ============================================================
# Fichier de configuration production — copier en .env.prod
# NE JAMAIS committer .env.prod dans git
# ============================================================

# --- Backend Flask ---
SECRET_KEY=CHANGER_MOI_valeur_aleatoire_forte
ADMIN_KEY=CHANGER_MOI_valeur_aleatoire_forte
DATABASE_PATH=/app/data/battleapp.db
FLASK_DEBUG=0
# Domaine réel séparé par des virgules, ex: https://kavernchampions.monpseudo.com
CORS_ORIGINS=https://kavernchampions.monpseudo.com

# --- Bot Twitch ---
TWITCH_BOT_TOKEN=oauth:VOTRE_ACCESS_TOKEN
TWITCH_BOT_NICK=NomDuBot
TWITCH_CHANNEL=nomdustreamer
TWITCH_CLIENT_ID=VOTRE_CLIENT_ID
TWITCH_CLIENT_SECRET=VOTRE_CLIENT_SECRET
TWITCH_REFRESH_TOKEN=VOTRE_REFRESH_TOKEN
API_BASE_URL=http://backend:5000
COOLDOWN_SECONDS=10

# Générer SECRET_KEY et ADMIN_KEY :
#   python -c "import secrets; print(secrets.token_hex(32))"
