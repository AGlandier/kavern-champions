# Twitch — compte bot
TWITCH_BOT_TOKEN=oauth:xxxxxxxxxxxx   # access token initial (remplacé par tokens.json après le 1er refresh)
TWITCH_BOT_NICK=KavernBot
TWITCH_CHANNEL=nomdustreamer

# Twitch App (dev.twitch.tv/console)
TWITCH_CLIENT_ID=xxxxxxxxxxxx
TWITCH_CLIENT_SECRET=xxxxxxxxxxxx
TWITCH_REFRESH_TOKEN=xxxxxxxxxxxx     # généré via le flow OAuth (voir README)

# Backend API
API_BASE_URL=http://localhost:5000
ADMIN_KEY=your_admin_key_here

# Optionnel
COOLDOWN_SECONDS=10
